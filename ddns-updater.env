# Space-separated list of URLs to notify when the public IP changes.
EXTERNAL_SERVER_URLS="https://example.com/update-ip https://another.example.com/update-ip"

# Optional stable identifier for the remote device. Defaults to `hostname -s`.
# DEVICE_ID=remote-gate

# Optional extra header, for example:
# AUTH_HEADER="Authorization: Bearer your-secret-token"

# Public IP discovery endpoint.
IP_API_URL=https://api.ipify.org

# Where the remote device stores the last successfully reported IP.
SAVE_FILE=/var/lib/ddns-updater/last_ip.txt
